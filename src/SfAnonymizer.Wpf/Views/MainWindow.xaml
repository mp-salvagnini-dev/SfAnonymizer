<Window x:Class="SfAnonymizer.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SfAnonymizer.Wpf.ViewModels"
        xmlns:conv="clr-namespace:SfAnonymizer.Wpf.Converters"
        Title="ITSM Ticket Anonymizer"
        Icon="/Assets/app.ico"
        Width="1100" Height="750" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnDragOver">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="ITSM Ticket Anonymizer"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Text="Anonymize sensitive data from ITSM ticket exports"
                       FontSize="13" Foreground="{StaticResource SubtleTextBrush}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- ═══ FILE INPUT ROW ═══ -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding InputFilePath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="10,8" FontSize="13"
                         IsReadOnly="True"
                         Background="#F0F0F0"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="#FFF8E1" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1"
                        Content="✕ Clear"
                        Style="{StaticResource BaseButtonStyle}"
                        Background="#E0E0E0" Foreground="{StaticResource TextBrush}"
                        Margin="8,0,0,0"
                        Command="{Binding ClearCommand}"
                        Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}" />

                <Button Grid.Column="2"
                        Content="📂 Browse..."
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0"
                        Click="BrowseFile_Click" />

                <Button Grid.Column="3"
                        Content="▶ Parse &amp; Detect"
                        Style="{StaticResource AccentButton}"
                        Margin="8,0,0,0"
                        Command="{Binding ParseFileCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT AREA ═══ -->
        <Grid Grid.Row="2" Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: COLUMN SELECTOR ─── -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                        <TextBlock Style="{StaticResource SectionHeader}"
                                   Text="🔍 Sensitive Columns"
                                   VerticalAlignment="Center" />
                        <Button HorizontalAlignment="Right"
                                Content="🗂 Categories"
                                FontSize="11" Padding="8,3"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ManageCategoriesCommand}" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Check columns to anonymize. Categories are auto-detected."
                               FontSize="11" Foreground="{StaticResource SubtleTextBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10" />

                    <Button DockPanel.Dock="Bottom"
                            Content="🔒 Anonymize Now"
                            Style="{StaticResource AccentButton}"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Stretch"
                            Command="{Binding AnonymizeCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DetectedColumns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6,4" Margin="0,1"
                                            CornerRadius="4"
                                            Background="{StaticResource PrimaryLightBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,6,0" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ColumnName}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ColumnName}" />

                                            <ComboBox Grid.Column="2"
                                                      SelectedItem="{Binding Category}"
                                                      ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      FontSize="10" Width="100"
                                                      Padding="4,2"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ─── RIGHT: TABBED PREVIEW / TRANSCODE ─── -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <TabControl Background="Transparent" BorderThickness="0">

                    <!-- Tab: Preview -->
                    <TabItem Header="{Binding PreviewTabHeader}">
                        <DataGrid ItemsSource="{Binding PreviewData}"
                                  AutoGenerateColumns="True"
                                  AutoGeneratingColumn="PreviewDataGrid_AutoGeneratingColumn"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="#F5F9FC"
                                  FontSize="12"
                                  BorderThickness="0" />
                    </TabItem>

                    <!-- Tab: Transcode Table -->
                    <TabItem Header="🔑 Transcode Table">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="Total replacements: " />
                                    <Run Text="{Binding TotalReplacements, Mode=OneWay}"
                                         FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                </TextBlock>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding TranscodeEntries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="#FFF8F0"
                                      FontSize="12"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Row" Binding="{Binding RowIndex}" Width="60" />
                                    <DataGridTextColumn Header="Column" Binding="{Binding ColumnName}" Width="140" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="100" />
                                    <DataGridTextColumn Header="Original" Binding="{Binding OriginalValue}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Anonymized" Binding="{Binding AnonymizedValue}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

        <!-- ═══ FOOTER: STATUS + EXPORT ═══ -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            Visibility="{Binding IsAnonymized, Converter={StaticResource BoolToVis}}">
                    <Button Content="💾 Export Anonymized Data"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,8,0"
                            Click="ExportAnonymized_Click" />
                    <Button Content="📋 Export Transcode Table"
                            Style="{StaticResource PrimaryButton}"
                            Click="ExportTranscode_Click" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar Width="18" Height="18" IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                 Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVis}}"
                            Margin="16,0,16,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center">
                        <Run Text="Rows: " />
                        <Run Text="{Binding TotalRows, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ DROP OVERLAY ═══ -->
        <Border x:Name="DropOverlay" Grid.RowSpan="4"
                Background="#CC1B5E7B" CornerRadius="12"
                Visibility="Collapsed" IsHitTestVisible="False">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="Drop CSV or Excel file here"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
